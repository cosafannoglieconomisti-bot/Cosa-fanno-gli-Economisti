DEBUG: Raw artifact: ['d90f387c-1e95-4758-bb65-39e6f889b751', 'I satelliti svelano il potere delle etnie', 1, [[['d88254b8-7892-4b3d-a584-266c76cd46be']]], 3, None, [None, [None, 2, None, [['d88254b8-7892-4b3d-a584-266c76cd46be']], 'it', True, 3], 'https://lh3.googleusercontent.com/notebooklm/AKXwDQGvssYHdwLWs2kj98nVF8uwjWeot95wKZmWuFr3iV1813TXHLtJDb-aA3gYRMHPLe12gu6LDwoUHS0YB5P3DTPrjuoXs5kfDE8eD2I8KpuMqJ6F-VoGwDb8m1atNO2Y6PiQFojT0ybXH3H_oTrEWqHshk75IxE=m140', 'https://lh3.googleusercontent.com/notebooklm/AKXwDQGvssYHdwLWs2kj98nVF8uwjWeot95wKZmWuFr3iV1813TXHLtJDb-aA3gYRMHPLe12gu6LDwoUHS0YB5P3DTPrjuoXs5kfDE8eD2I8KpuMqJ6F-VoGwDb8m1atNO2Y6PiQFojT0ybXH3H_oTrEWqHshk75IxE=m140-dv', False, [['https://lh3.googleusercontent.com/notebooklm/AKXwDQGvssYHdwLWs2kj98nVF8uwjWeot95wKZmWuFr3iV1813TXHLtJDb-aA3gYRMHPLe12gu6LDwoUHS0YB5P3DTPrjuoXs5kfDE8eD2I8KpuMqJ6F-VoGwDb8m1atNO2Y6PiQFojT0ybXH3H_oTrEWqHshk75IxE=m140-dv', 4, 'audio/mp4'], ['https://lh3.googleusercontent.com/notebooklm/AKXwDQGvssYHdwLWs2kj98nVF8uwjWeot95wKZmWuFr3iV1813TXHLtJDb-aA3gYRMHPLe12gu6LDwoUHS0YB5P3DTPrjuoXs5kfDE8eD2I8KpuMqJ6F-VoGwDb8m1atNO2Y6PiQFojT0ybXH3H_oTrEWqHshk75IxE=m140', 1, 'audio/mp4'], ['https://lh3.googleusercontent.com/notebooklm/AKXwDQGvssYHdwLWs2kj98nVF8uwjWeot95wKZmWuFr3iV1813TXHLtJDb-aA3gYRMHPLe12gu6LDwoUHS0YB5P3DTPrjuoXs5kfDE8eD2I8KpuMqJ6F-VoGwDb8m1atNO2Y6PiQFojT0ybXH3H_oTrEWqHshk75IxE=mm,hls', 2], ['https://lh3.googleusercontent.com/notebooklm/AKXwDQGvssYHdwLWs2kj98nVF8uwjWeot95wKZmWuFr3iV1813TXHLtJDb-aA3gYRMHPLe12gu6LDwoUHS0YB5P3DTPrjuoXs5kfDE8eD2I8KpuMqJ6F-VoGwDb8m1atNO2Y6PiQFojT0ybXH3H_oTrEWqHshk75IxE=mm,dash', 3]], [750, 570958000]], None, None, None, [1771941087, 278728000], None, None, None, None, [1771939928, 738082000], None, None, None, 1, None, 'MTc3MTk0MTA4Ny0yNzg3MjgwMDA=']
