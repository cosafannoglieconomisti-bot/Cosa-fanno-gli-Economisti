DEBUG: Raw artifact: ['1270ec73-06ee-47bb-a419-bbae58dd1ba5', 'Mogano: il prezzo di una legge', 3, [[['c9ed2633-09ff-4b70-8ec1-0e9c6dda9fdd']]], 3, None, None, None, [None, 'https://lh3.googleusercontent.com/notebooklm/AKXwDQGOh-M5oms6HdiCXv859l8Nkko5ttYiK6loOPbnlN50ayrb8et3ZlnYZV-IrtPO9ItblIYQ5Zpu3NNNvxxuAojk_Ql2D5fmXmixFNiUU1E02ENHAGV7M_NvRn6ifVhMIuIMG4MI20PHtJk00jmVSJBxQet0dus=m22', [[['c9ed2633-09ff-4b70-8ec1-0e9c6dda9fdd']], 'it', "Struttura il video come uno studio di caso ammonitore sull'applicazione delle normative ambientali, mantenendo un tono molto serio e basato sull'evidenza, ma con lieve accento bolognese", None, 1, 1], 'https://lh3.googleusercontent.com/notebooklm/AKXwDQGOh-M5oms6HdiCXv859l8Nkko5ttYiK6loOPbnlN50ayrb8et3ZlnYZV-IrtPO9ItblIYQ5Zpu3NNNvxxuAojk_Ql2D5fmXmixFNiUU1E02ENHAGV7M_NvRn6ifVhMIuIMG4MI20PHtJk00jmVSJBxQet0dus=m22-dv', [['https://lh3.googleusercontent.com/notebooklm/AKXwDQGOh-M5oms6HdiCXv859l8Nkko5ttYiK6loOPbnlN50ayrb8et3ZlnYZV-IrtPO9ItblIYQ5Zpu3NNNvxxuAojk_Ql2D5fmXmixFNiUU1E02ENHAGV7M_NvRn6ifVhMIuIMG4MI20PHtJk00jmVSJBxQet0dus=m22', 1, 'video/mp4'], ['https://lh3.googleusercontent.com/notebooklm/AKXwDQGOh-M5oms6HdiCXv859l8Nkko5ttYiK6loOPbnlN50ayrb8et3ZlnYZV-IrtPO9ItblIYQ5Zpu3NNNvxxuAojk_Ql2D5fmXmixFNiUU1E02ENHAGV7M_NvRn6ifVhMIuIMG4MI20PHtJk00jmVSJBxQet0dus=mm,hls', 2], ['https://lh3.googleusercontent.com/notebooklm/AKXwDQGOh-M5oms6HdiCXv859l8Nkko5ttYiK6loOPbnlN50ayrb8et3ZlnYZV-IrtPO9ItblIYQ5Zpu3NNNvxxuAojk_Ql2D5fmXmixFNiUU1E02ENHAGV7M_NvRn6ifVhMIuIMG4MI20PHtJk00jmVSJBxQet0dus=mm,dash', 3], ['https://lh3.googleusercontent.com/notebooklm/AKXwDQGOh-M5oms6HdiCXv859l8Nkko5ttYiK6loOPbnlN50ayrb8et3ZlnYZV-IrtPO9ItblIYQ5Zpu3NNNvxxuAojk_Ql2D5fmXmixFNiUU1E02ENHAGV7M_NvRn6ifVhMIuIMG4MI20PHtJk00jmVSJBxQet0dus=m22-dv', 4, 'video/mp4']], [467, 124999000]], None, [1772464958, 545441000], None, None, None, None, [1772463945, 298681000], None, None, None, 1, None, 'MTc3MjQ2NDk1OC01NDU0NDEwMDA=']
